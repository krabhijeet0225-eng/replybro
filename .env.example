# ─────────────────────────────────────────────────────────────
# .env.example  —  copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# On Replit: add each variable in the Secrets tab instead of a .env file.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (provided automatically by Replit DB)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Express session secret — generate a long random string
SESSION_SECRET=replace-with-a-long-random-string

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace-me

# Node environment
NODE_ENV=development

# Port the API server listens on (Replit sets this automatically)
PORT=8080
